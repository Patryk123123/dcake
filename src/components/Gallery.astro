---
const gallery = [
  { title: 'Tort artystyczny', image: '/images/gallery-1.jpeg', size: 'large' },
  { title: 'Wesele', image: '/images/gallery-2.jpeg', size: 'small' },
  { title: 'Słodki stół', image: '/images/gallery-3.jpeg', size: 'small' },
  { title: 'Desery', image: '/images/gallery-4.jpeg', size: 'wide' },
  { title: 'Personalizacja', image: '/images/gallery-5.jpeg', size: 'small' },
  { title: 'Detale', image: '/images/gallery-6.jpeg', size: 'small' },
];
---

<!-- GALLERY -->
<section id="galeria" class="bg-white px-5 py-24 lg:px-8">
  <div class="mx-auto max-w-7xl">
    <div class="mb-14 grid gap-8 lg:grid-cols-[0.8fr_1.2fr]">
      <p class="text-xs font-bold uppercase tracking-[0.42em] text-[#D3A373]">
        Galeria
      </p>
      <h2 class="display-font max-w-5xl text-5xl font-semibold leading-none tracking-[-0.055em] md:text-7xl">
        Zdjęcia mają sprzedawać jakość szybciej niż tekst.
      </h2>
    </div>

    <div class="grid auto-rows-[260px] gap-5 md:grid-cols-4 md:auto-rows-[280px]">
      {gallery.map((item) => (
        <figure
          class={`group relative overflow-hidden rounded-[2.4rem] bg-[#FFF5E1] p-2 ring-1 ring-[#36474F]/10
            ${item.size === 'large' ? 'md:col-span-2 md:row-span-2' : ''}
            ${item.size === 'wide' ? 'md:col-span-2' : ''}
          `}
        >
          <div class="relative h-full overflow-hidden rounded-[1.9rem]">
            <img src={item.image} alt={item.title} class="h-full w-full object-cover transition duration-700 group-hover:scale-105" />
            <div class="absolute inset-0 bg-gradient-to-t from-[#36474F]/65 via-transparent to-transparent"></div>
            <figcaption class="absolute bottom-6 left-6 rounded-full bg-[#FFF5E1]/90 px-5 py-2 text-xs font-bold uppercase tracking-[0.25em] text-[#36474F]">
              {item.title}
            </figcaption>
          </div>
        </figure>
      ))}
    </div>
  </div>
</section>
