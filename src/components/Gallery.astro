---
const gallery = [
  {
    title: 'Tort artystyczny',
    subtitle: 'personalizowana realizacja',
    image: '/images/gallery-1.jpeg',
    alt: 'Tort artystyczny The Cake',
    className: 'lg:col-span-2 lg:row-span-2',
    imageClass: 'object-center',
  },
  {
    title: 'Tort weselny',
    subtitle: 'elegancja i detal',
    image: '/images/gallery-2.jpeg',
    alt: 'Tort weselny The Cake',
    className: '',
    imageClass: 'object-center',
  },
  {
    title: 'Słodki stół',
    subtitle: 'kompleksowa oprawa',
    image: '/images/gallery-3.jpeg',
    alt: 'Słodki stół The Cake',
    className: '',
    imageClass: 'object-center',
  },
  {
    title: 'Desery',
    subtitle: 'małe formy, duży efekt',
    image: '/images/gallery-4.jpeg',
    alt: 'Desery The Cake',
    className: 'lg:col-span-2',
    imageClass: 'object-center',
  },
  {
    title: 'Personalizacja',
    subtitle: 'projekt pod okazję',
    image: '/images/gallery-5.jpeg',
    alt: 'Tort personalizowany The Cake',
    className: '',
    imageClass: 'object-center',
  },
  {
    title: 'Detale',
    subtitle: 'estetyka wykończenia',
    image: '/images/gallery-6.jpeg',
    alt: 'Detale tortu The Cake',
    className: '',
    imageClass: 'object-center',
  },
];
---

<!-- GALLERY -->
<section id="galeria" class="relative overflow-hidden bg-white px-5 py-24 lg:px-8">
  <div class="absolute left-0 top-0 h-96 w-96 rounded-full bg-[#F6CED7]/35 blur-3xl"></div>
  <div class="absolute bottom-0 right-0 h-96 w-96 rounded-full bg-[#D3A373]/20 blur-3xl"></div>

  <div class="relative mx-auto max-w-7xl">
    <!-- Nagłówek sekcji -->
    <div class="mb-14 grid gap-10 lg:grid-cols-[0.85fr_1.15fr] lg:items-end">
      <div>
        <p class="text-xs font-bold uppercase tracking-[0.42em] text-[#D3A373]">
          Galeria realizacji
        </p>

        <h2 class="display-font mt-4 max-w-3xl text-5xl font-semibold leading-[0.9] tracking-[-0.06em] text-[#36474F] md:text-7xl">
          Zdjęcia, które budują zaufanie.
        </h2>
      </div>

      <div class="max-w-xl lg:justify-self-end">
        <p class="text-lg leading-8 text-[#36474F]/70">
          W tej sekcji pokazujemy styl The Cake: eleganckie torty, dopracowane detale,
          słodkie stoły i realizacje tworzone indywidualnie pod konkretne wydarzenie.
        </p>

        <div class="mt-7 flex flex-wrap gap-3">
          <span class="rounded-full bg-[#FFF5E1] px-5 py-2 text-xs font-bold uppercase tracking-[0.2em] text-[#36474F]/70 ring-1 ring-[#36474F]/10">
            torty
          </span>
          <span class="rounded-full bg-[#FFF5E1] px-5 py-2 text-xs font-bold uppercase tracking-[0.2em] text-[#36474F]/70 ring-1 ring-[#36474F]/10">
            wesela
          </span>
          <span class="rounded-full bg-[#FFF5E1] px-5 py-2 text-xs font-bold uppercase tracking-[0.2em] text-[#36474F]/70 ring-1 ring-[#36474F]/10">
            słodkie stoły
          </span>
          <span class="rounded-full bg-[#FFF5E1] px-5 py-2 text-xs font-bold uppercase tracking-[0.2em] text-[#36474F]/70 ring-1 ring-[#36474F]/10">
            desery
          </span>
        </div>
      </div>
    </div>

    <!-- Duża galeria -->
    <div class="grid auto-rows-[260px] gap-5 md:grid-cols-2 lg:grid-cols-4 lg:auto-rows-[280px]">
      {gallery.map((item) => (
        <figure
          class={`group relative overflow-hidden rounded-[2.4rem] bg-[#FFF5E1] p-2 shadow-xl shadow-[#36474F]/5 ring-1 ring-[#36474F]/10 ${item.className}`}
        >
          <div class="relative h-full overflow-hidden rounded-[1.9rem]">
            <img
              src={item.image}
              alt={item.alt}
              class={`h-full w-full object-cover ${item.imageClass} transition duration-700 group-hover:scale-105`}
            />

            <div class="absolute inset-0 bg-gradient-to-t from-[#36474F]/75 via-[#36474F]/10 to-transparent"></div>

            <div class="absolute left-5 top-5 rounded-full bg-[#FFF5E1]/90 px-4 py-2 text-[0.65rem] font-bold uppercase tracking-[0.22em] text-[#36474F] backdrop-blur">
              The Cake
            </div>

            <figcaption class="absolute bottom-0 left-0 right-0 p-6 text-white">
              <p class="text-xs font-bold uppercase tracking-[0.28em] text-[#D3A373]">
                {item.subtitle}
              </p>
              <p class="display-font mt-2 text-3xl font-semibold leading-none tracking-[-0.04em]">
                {item.title}
              </p>
            </figcaption>
          </div>
        </figure>
      ))}
    </div>

    <!-- Dolny opis / CTA -->
    <div class="mt-12 grid gap-6 rounded-[2.5rem] bg-[#FFF5E1] p-7 ring-1 ring-[#36474F]/10 md:grid-cols-[1fr_auto] md:items-center md:p-9">
      <div>
        <p class="text-xs font-bold uppercase tracking-[0.35em] text-[#D3A373]">
          Portfolio
        </p>
        <p class="display-font mt-3 max-w-3xl text-3xl font-semibold leading-tight tracking-[-0.04em] text-[#36474F] md:text-4xl">
          Każda realizacja jest inna — dopasowana do okazji, liczby gości i stylu wydarzenia.
        </p>
      </div>

      <a
        href="#kontakt"
        class="inline-flex justify-center rounded-full bg-[#36474F] px-7 py-4 text-sm font-bold text-white transition hover:-translate-y-0.5 hover:bg-[#D3A373]"
      >
        Zapytaj o podobną realizację
      </a>
    </div>
  </div>
</section>