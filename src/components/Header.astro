<!-- HEADER -->
<header class="fixed left-0 top-0 z-50 w-full px-4 pt-4">
  <div class="mx-auto max-w-7xl">
    <div class="flex items-center justify-between rounded-full border border-[#36474F]/10 bg-[#FFF5E1]/85 px-4 py-3 shadow-xl shadow-[#36474F]/5 backdrop-blur-xl md:px-5">
      
      <!-- LOGO -->
      <a href="#start" class="group flex items-center gap-3">
        <span class="flex h-11 w-11 items-center justify-center rounded-full bg-[#36474F] text-sm font-black text-white transition group-hover:bg-[#D3A373]">
          TC
        </span>

        <span class="leading-none">
          <span class="display-font block text-2xl font-semibold tracking-[-0.04em] text-[#36474F]">
            The Cake
          </span>
          <span class="hidden text-[0.6rem] font-bold uppercase tracking-[0.28em] text-[#36474F]/55 sm:block">
            pracownia cukiernicza
          </span>
        </span>
      </a>

      <!-- DESKTOP NAV -->
      <nav class="hidden items-center gap-7 text-sm font-semibold text-[#36474F]/70 lg:flex">
        <a href="#oferta" class="transition hover:text-[#D3A373]">Oferta</a>
        <a href="#galeria" class="transition hover:text-[#D3A373]">Galeria</a>
        <a href="#proces" class="transition hover:text-[#D3A373]">Proces</a>
        <a href="#faq" class="transition hover:text-[#D3A373]">FAQ</a>
        <a href="#kontakt" class="transition hover:text-[#D3A373]">Kontakt</a>
      </nav>

      <!-- CTA DESKTOP -->
      <a
        href="#kontakt"
        class="hidden rounded-full bg-[#36474F] px-6 py-3 text-sm font-bold text-white shadow-lg shadow-[#36474F]/10 transition hover:-translate-y-0.5 hover:bg-[#D3A373] md:inline-flex"
      >
        Zapytaj o termin
      </a>

      <!-- MOBILE MENU -->
      <details class="relative lg:hidden">
        <summary class="flex h-11 w-11 cursor-pointer list-none items-center justify-center rounded-full border border-[#36474F]/10 bg-white/70 text-[#36474F] transition hover:bg-white">
          <span class="sr-only">Otwórz menu</span>
          <span class="text-2xl leading-none">≡</span>
        </summary>

        <div class="absolute right-0 top-14 w-72 overflow-hidden rounded-[2rem] border border-[#36474F]/10 bg-[#FFF5E1] p-3 shadow-2xl shadow-[#36474F]/15">
          <nav class="flex flex-col text-sm font-semibold text-[#36474F]">
            <a href="#oferta" class="rounded-full px-5 py-3 transition hover:bg-white">Oferta</a>
            <a href="#galeria" class="rounded-full px-5 py-3 transition hover:bg-white">Galeria</a>
            <a href="#proces" class="rounded-full px-5 py-3 transition hover:bg-white">Proces zamówienia</a>
            <a href="#faq" class="rounded-full px-5 py-3 transition hover:bg-white">FAQ</a>
            <a href="#kontakt" class="rounded-full px-5 py-3 transition hover:bg-white">Kontakt</a>

            <a
              href="#kontakt"
              class="mt-3 rounded-full bg-[#36474F] px-5 py-3 text-center text-white transition hover:bg-[#D3A373]"
            >
              Wyślij zapytanie
            </a>
          </nav>
        </div>
      </details>
    </div>
  </div>
</header>