<!-- HERO -->
<section id="start" class="relative isolate min-h-screen overflow-hidden bg-[#FFF5E1] pt-24">
  <!-- tło / klimat -->
  <div class="absolute inset-0 -z-20 bg-[#FFF5E1]"></div>
  <div class="absolute inset-0 -z-10 opacity-[0.35] soft-grid"></div>
  <div class="absolute -right-40 top-16 -z-10 h-[36rem] w-[36rem] rounded-full bg-[#F6CED7]/70 blur-3xl"></div>
  <div class="absolute -bottom-48 -left-48 -z-10 h-[38rem] w-[38rem] rounded-full bg-[#D3A373]/35 blur-3xl"></div>

  <!-- duże dekoracyjne logo w tle -->
  <div class="pointer-events-none absolute left-1/2 top-[52%] -z-10 hidden -translate-x-1/2 -translate-y-1/2 select-none lg:block">
    <p class="display-font whitespace-nowrap text-[13rem] font-semibold leading-none tracking-[-0.08em] text-[#36474F]/[0.035] xl:text-[16rem]">
      The Cake
    </p>
  </div>

  <div class="mx-auto grid min-h-[calc(100vh-6rem)] max-w-7xl items-center gap-12 px-5 py-12 lg:grid-cols-[0.88fr_1.12fr] lg:px-8">
    <!-- LEWA STRONA -->
    <div class="relative z-10">
      <div class="mb-7 inline-flex items-center gap-3 rounded-full border border-[#36474F]/10 bg-white/60 px-4 py-2 backdrop-blur">
        <span class="h-2 w-2 rounded-full bg-[#D3A373]"></span>
        <p class="text-[0.68rem] font-bold uppercase tracking-[0.32em] text-[#36474F]/70">
          Pracownia cukiernicza · Chełm i okolice
        </p>
      </div>

      <h1 class="display-font max-w-4xl text-6xl font-semibold leading-[0.88] tracking-[-0.07em] text-[#36474F] sm:text-7xl md:text-8xl xl:text-[8.8rem]">
        Torty tworzone z wyczuciem.
      </h1>

      <p class="mt-7 max-w-xl text-lg leading-8 text-[#36474F]/72">
        Artystyczne torty, słodkie stoły i desery na zamówienie — dopasowane do stylu
        wydarzenia, estetyki przyjęcia i oczekiwań klienta.
      </p>

      <div class="mt-9 flex flex-col gap-4 sm:flex-row">
        <a
          href="#kontakt"
          class="group inline-flex items-center justify-center rounded-full bg-[#36474F] px-8 py-4 text-sm font-bold text-white shadow-xl shadow-[#36474F]/15 transition hover:-translate-y-0.5 hover:bg-[#D3A373]"
        >
          Zapytaj o termin
          <span class="ml-2 transition group-hover:translate-x-1">→</span>
        </a>

        <a
          href="#galeria"
          class="inline-flex items-center justify-center rounded-full border border-[#36474F]/15 bg-white/60 px-8 py-4 text-sm font-bold text-[#36474F] backdrop-blur transition hover:-translate-y-0.5 hover:bg-white"
        >
          Zobacz realizacje
        </a>
      </div>

      <!-- atuty -->
      <div class="mt-12 grid max-w-2xl gap-4 sm:grid-cols-3">
        <div class="rounded-[1.6rem] bg-white/65 p-5 ring-1 ring-[#36474F]/10 backdrop-blur">
          <p class="display-font text-3xl font-semibold leading-none text-[#36474F]">01</p>
          <p class="mt-3 text-xs font-bold uppercase tracking-[0.18em] text-[#36474F]/55">
            projekty indywidualne
          </p>
        </div>

        <div class="rounded-[1.6rem] bg-white/65 p-5 ring-1 ring-[#36474F]/10 backdrop-blur">
          <p class="display-font text-3xl font-semibold leading-none text-[#36474F]">30 km</p>
          <p class="mt-3 text-xs font-bold uppercase tracking-[0.18em] text-[#36474F]/55">
            lokalny dowóz
          </p>
        </div>

        <div class="rounded-[1.6rem] bg-white/65 p-5 ring-1 ring-[#36474F]/10 backdrop-blur">
          <p class="display-font text-3xl font-semibold leading-none text-[#36474F]">B2B</p>
          <p class="mt-3 text-xs font-bold uppercase tracking-[0.18em] text-[#36474F]/55">
            firmy i eventy
          </p>
        </div>
      </div>
    </div>

    <!-- PRAWA STRONA / ZDJĘCIA -->
    <div class="relative z-10">
      <!-- małe pionowe oznaczenie -->
      <div class="absolute -left-5 top-14 z-20 hidden rounded-full bg-[#D3A373] px-6 py-3 text-xs font-bold uppercase tracking-[0.24em] text-white shadow-2xl shadow-[#36474F]/15 lg:block">
        handmade
      </div>

      <div class="grid gap-5 md:grid-cols-[0.72fr_1fr]">
        <!-- kolumna małych zdjęć -->
        <div class="hidden flex-col gap-5 pt-16 md:flex">
          <div class="group relative overflow-hidden rounded-[2rem] bg-white p-2 ring-1 ring-[#36474F]/12 shadow-xl shadow-[#36474F]/10">
            <div class="relative aspect-[4/5] overflow-hidden rounded-[1.55rem]">
              <img
                src="/images/gallery-2.jpeg"
                alt="Tort The Cake"
                class="h-full w-full object-cover transition duration-700 group-hover:scale-105"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-[#36474F]/55 via-transparent to-transparent"></div>
              <p class="absolute bottom-5 left-5 rounded-full bg-[#FFF5E1]/90 px-4 py-2 text-[0.65rem] font-bold uppercase tracking-[0.22em] text-[#36474F]">
                torty
              </p>
            </div>
          </div>

          <div class="rounded-[2rem] bg-[#36474F] p-6 text-white shadow-xl shadow-[#36474F]/10">
            <p class="text-xs font-bold uppercase tracking-[0.3em] text-[#D3A373]">
              The Cake
            </p>
            <p class="display-font mt-4 text-3xl font-semibold leading-none tracking-[-0.035em]">
              Piękno, smak i detal w jednej realizacji.
            </p>
          </div>
        </div>

        <!-- główne zdjęcie -->
        <div class="image-frame group relative overflow-hidden rounded-[3rem] bg-white p-3">
          <div class="relative aspect-[4/5] overflow-hidden rounded-[2.35rem]">
            <img
              src="/images/hero.jpeg"
              alt="Tort artystyczny The Cake"
              class="h-full w-full object-cover object-center transition duration-700 group-hover:scale-[1.035]"
            />

            <div class="absolute inset-0 bg-gradient-to-t from-[#36474F]/78 via-[#36474F]/10 to-transparent"></div>

            <!-- tekst na zdjęciu -->
            <div class="absolute left-0 right-0 top-0 flex justify-between p-6 md:p-8">
              <p class="rounded-full bg-[#FFF5E1]/90 px-4 py-2 text-[0.65rem] font-bold uppercase tracking-[0.24em] text-[#36474F]">
                torty
              </p>
              <p class="rounded-full bg-white/20 px-4 py-2 text-[0.65rem] font-bold uppercase tracking-[0.24em] text-white backdrop-blur">
                premium
              </p>
            </div>

            <div class="absolute bottom-0 left-0 right-0 p-7 text-white md:p-10">
              <p class="text-xs font-bold uppercase tracking-[0.36em] text-[#D3A373]">
                torty · słodkie stoły · desery
              </p>

              <p class="display-font mt-4 max-w-md text-4xl font-semibold leading-none tracking-[-0.045em] md:text-5xl">
                Każda realizacja powstaje na zamówienie.
              </p>

              <p class="mt-5 max-w-md text-sm leading-6 text-white/72">
                Estetyczne wypieki na wesela, rodzinne przyjęcia i wydarzenia firmowe.
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- karta podpisu -->
      <div class="absolute -bottom-7 right-4 z-20 hidden w-80 rounded-[2rem] bg-white p-6 shadow-2xl shadow-[#36474F]/15 ring-1 ring-[#36474F]/10 xl:block">
        <div class="flex items-start gap-4">
          <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-[#F6CED7] text-sm font-black text-[#36474F]">
            TC
          </div>
          <div>
            <p class="text-xs font-bold uppercase tracking-[0.3em] text-[#D3A373]">
              signature style
            </p>
            <p class="display-font mt-2 text-3xl leading-none tracking-[-0.035em] text-[#36474F]">
              Elegancko, ciepło, z detalem.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>