---
const offers = [
  {
    number: '01',
    title: 'Torty okolicznościowe',
    tag: 'urodziny / chrzest / komunia / jubileusz',
    text: 'Personalizowane torty tworzone pod konkretną okazję, styl wydarzenia i oczekiwania klienta.',
    image: '/images/gallery-1.jpeg',
  },
  {
    number: '02',
    title: 'Torty weselne',
    tag: 'ślub / przyjęcie / elegancka realizacja',
    text: 'Jedno- i wielopiętrowe torty weselne dopasowane do dekoracji, sali i charakteru uroczystości.',
    image: '/images/offer-wedding.jpeg',
  },
  {
    number: '03',
    title: 'Słodkie stoły',
    tag: 'desery / dekoracja / montaż',
    text: 'Kompleksowa oprawa słodkiej części wydarzenia — od deserów po dekorację i montaż na miejscu.',
    image: '/images/offer-sweet-table.jpeg',
  },
  {
    number: '04',
    title: 'Boxy i oferta firmowa',
    tag: 'prezenty / eventy / B2B',
    text: 'Słodkie upominki, boxy prezentowe i realizacje dla firm, eventów oraz lokalnych partnerów.',
    image: '/images/offer-business.jpeg',
  },
];
---

<!-- OFFER -->
<section id="oferta" class="relative overflow-hidden bg-[#FFF5E1] px-5 py-24 lg:px-8">
  <div class="absolute right-0 top-0 h-96 w-96 rounded-full bg-[#F6CED7]/45 blur-3xl"></div>

  <div class="relative mx-auto max-w-7xl">
    <div class="mb-14 flex flex-col justify-between gap-8 md:flex-row md:items-end">
      <div>
        <p class="text-xs font-bold uppercase tracking-[0.42em] text-[#D3A373]">
          Oferta
        </p>
        <h2 class="display-font mt-4 max-w-3xl text-5xl font-semibold leading-none tracking-[-0.055em] md:text-7xl">
          Słodka oprawa ważnych okazji.
        </h2>
      </div>

      <p class="max-w-md leading-8 text-[#36474F]/70">
        Oferta została ułożona tak, żeby użytkownik od razu widział, czym zajmuje się The Cake:
        torty, wesela, słodkie stoły i realizacje firmowe.
      </p>
    </div>

    <div class="grid gap-6">
      {offers.map((offer, index) => (
        <article class={`group grid overflow-hidden rounded-[3rem] bg-white p-3 ring-1 ring-[#36474F]/10 transition hover:-translate-y-1 hover:shadow-2xl hover:shadow-[#36474F]/12 lg:grid-cols-2 ${index % 2 === 1 ? 'lg:[&>*:first-child]:order-2' : ''}`}>
          <div class="relative min-h-[360px] overflow-hidden rounded-[2.4rem] md:min-h-[480px]">
            <img src={offer.image} alt={offer.title} class="h-full w-full object-cover transition duration-700 group-hover:scale-105" />
            <div class="absolute inset-0 bg-gradient-to-t from-[#36474F]/72 via-[#36474F]/10 to-transparent"></div>

            <div class="absolute left-7 top-7 rounded-full bg-[#FFF5E1]/90 px-5 py-2 text-xs font-bold uppercase tracking-[0.25em] text-[#36474F]">
              {offer.tag}
            </div>

            <div class="absolute bottom-7 left-7 right-7 text-white">
              <p class="display-font text-6xl leading-none text-[#D3A373]">{offer.number}</p>
              <h3 class="display-font mt-3 text-5xl font-semibold leading-none tracking-[-0.04em]">
                {offer.title}
              </h3>
            </div>
          </div>

          <div class="flex min-h-[360px] flex-col justify-between p-7 md:p-12">
            <div>
              <p class="text-xs font-bold uppercase tracking-[0.36em] text-[#D3A373]">The Cake offer</p>
              <p class="display-font mt-8 max-w-xl text-4xl font-semibold leading-tight tracking-[-0.04em] md:text-5xl">
                Projekt dopasowany do okazji, nie gotowy produkt z katalogu.
              </p>
            </div>

            <div>
              <p class="max-w-xl text-lg leading-8 text-[#36474F]/70">{offer.text}</p>
              <a href="#kontakt" class="mt-8 inline-flex rounded-full bg-[#36474F] px-7 py-3 text-sm font-bold text-white transition hover:bg-[#D3A373]">
                Zapytaj o realizację
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
