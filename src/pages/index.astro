---
import Layout from '../layouts/Layout.astro';

import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import BrandStatement from '../components/BrandStatement.astro';
import Offer from '../components/Offer.astro';
import Gallery from '../components/Gallery.astro';
import Process from '../components/Process.astro';
import AreaB2B from '../components/AreaB2B.astro';
import ContactFAQ from '../components/ContactFAQ.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <main class="bg-[#FFF5E1] text-[#36474F]">
    <style is:global>
      @import url('https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Playfair+Display:wght@500;600;700&display=swap');

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        font-family: 'Manrope', system-ui, sans-serif;
        background: #FFF5E1;
        color: #36474F;
      }

      .display-font {
        font-family: 'Playfair Display', Georgia, serif;
      }

      .soft-grid {
        background-image:
          linear-gradient(rgba(54, 71, 79, 0.055) 1px, transparent 1px),
          linear-gradient(90deg, rgba(54, 71, 79, 0.055) 1px, transparent 1px);
        background-size: 42px 42px;
      }

      .image-frame {
        border: 1px solid rgba(54, 71, 79, 0.18);
        box-shadow:
          0 28px 80px rgba(54, 71, 79, 0.14),
          inset 0 0 0 10px rgba(255, 245, 225, 0.65);
      }
    </style>

    <Header />
    <Hero />
    <BrandStatement />
    <Offer />
    <Gallery />
    <Process />
    <AreaB2B />
    <ContactFAQ />
    <Footer />
  </main>
</Layout>