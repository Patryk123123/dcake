---
import Layout from '../layouts/Layout.astro';

const brand = {
  cream: '#FFF5E1',
  pink: '#F6CED7',
  caramel: '#D3A373',
  dark: '#36474F',
};

const offers = [
  {
    number: '01',
    title: 'Torty okolicznościowe',
    tag: 'urodziny / chrzest / komunia / jubileusz',
    text: 'Personalizowane torty tworzone pod konkretną okazję, styl wydarzenia i oczekiwania klienta.',
    image: '/images/gallery-1.jpeg',
  },
  {
    number: '02',
    title: 'Torty weselne',
    tag: 'ślub / przyjęcie / elegancka realizacja',
    text: 'Jedno- i wielopiętrowe torty weselne dopasowane do dekoracji, sali i charakteru uroczystości.',
    image: '/images/offer-wedding.jpeg',
  },
  {
    number: '03',
    title: 'Słodkie stoły',
    tag: 'desery / dekoracja / montaż',
    text: 'Kompleksowa oprawa słodkiej części wydarzenia — od deserów po dekorację i montaż na miejscu.',
    image: '/images/offer-sweet-table.jpeg',
  },
  {
    number: '04',
    title: 'Boxy i oferta firmowa',
    tag: 'prezenty / eventy / B2B',
    text: 'Słodkie upominki, boxy prezentowe i realizacje dla firm, eventów oraz lokalnych partnerów.',
    image: '/images/offer-business.jpeg',
  },
];

const gallery = [
  { title: 'Tort artystyczny', image: '/images/gallery-1.jpeg', size: 'large' },
  { title: 'Wesele', image: '/images/gallery-2.jpeg', size: 'small' },
  { title: 'Słodki stół', image: '/images/gallery-3.jpeg', size: 'small' },
  { title: 'Desery', image: '/images/gallery-4.jpeg', size: 'wide' },
  { title: 'Personalizacja', image: '/images/gallery-5.jpeg', size: 'small' },
  { title: 'Detale', image: '/images/gallery-6.jpeg', size: 'small' },
];

const steps = [
  ['01', 'Zapytanie', 'Podajesz datę, miejscowość, liczbę osób i rodzaj realizacji.'],
  ['02', 'Koncepcja', 'Ustalamy styl, smak, inspiracje, kolorystykę i zakres usługi.'],
  ['03', 'Wycena', 'Otrzymujesz indywidualną propozycję przygotowaną pod wydarzenie.'],
  ['04', 'Realizacja', 'The Cake przygotowuje tort, desery lub słodki stół z dbałością o detale.'],
];

const faqs = [
  ['Ile wcześniej złożyć zamówienie?', 'Najlepiej minimum 2–3 tygodnie wcześniej. Przy weselach i słodkich stołach warto napisać z większym wyprzedzeniem.'],
  ['Czy można wysłać inspiracje?', 'Tak. Zdjęcia inspiracyjne, kolorystyka wydarzenia i opis stylu bardzo pomagają przygotować dobrą propozycję.'],
  ['Czy jest dowóz?', 'Tak, realizacje wykonywane są lokalnie w okolicach Chełma. Przy większych zamówieniach możliwy jest dowóz i montaż.'],
  ['Czy przygotowujecie ofertę dla firm?', 'Tak. Możliwe są boxy prezentowe, słodkie stoły na eventy, zamówienia sezonowe i indywidualne realizacje B2B.'],
];
---

<Layout>
  <main class="bg-[#FFF5E1] text-[#36474F]">
    <style is:global>
      @import url('https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700&family=Playfair+Display:wght@500;600;700&display=swap');

      html {
        scroll-behavior: smooth;
      }

      body {
        font-family: 'Manrope', system-ui, sans-serif;
        background: #FFF5E1;
      }

      .display-font {
        font-family: 'Playfair Display', Georgia, serif;
      }

      .soft-grid {
        background-image:
          linear-gradient(rgba(54, 71, 79, 0.055) 1px, transparent 1px),
          linear-gradient(90deg, rgba(54, 71, 79, 0.055) 1px, transparent 1px);
        background-size: 42px 42px;
      }

      .image-frame {
        border: 1px solid rgba(54, 71, 79, 0.18);
        box-shadow:
          0 28px 80px rgba(54, 71, 79, 0.14),
          inset 0 0 0 10px rgba(255, 245, 225, 0.65);
      }
    </style>

    <!-- HEADER -->
    <header class="fixed left-0 top-0 z-50 w-full border-b border-[#36474F]/10 bg-[#FFF5E1]/88 backdrop-blur-xl">
      <div class="mx-auto flex max-w-7xl items-center justify-between px-5 py-4 lg:px-8">
        <a href="#start" class="flex items-center gap-3">
          <span class="flex h-9 w-9 items-center justify-center rounded-full bg-[#36474F] text-sm font-semibold text-white">
            TC
          </span>
          <span class="text-sm font-bold uppercase tracking-[0.32em] text-[#36474F]">
            The Cake
          </span>
        </a>

        <nav class="hidden items-center gap-8 text-sm font-medium text-[#36474F]/70 md:flex">
          <a href="#oferta" class="hover:text-[#D3A373]">Oferta</a>
          <a href="#galeria" class="hover:text-[#D3A373]">Galeria</a>
          <a href="#proces" class="hover:text-[#D3A373]">Proces</a>
          <a href="#faq" class="hover:text-[#D3A373]">FAQ</a>
          <a href="#kontakt" class="hover:text-[#D3A373]">Kontakt</a>
        </nav>

        <a href="#kontakt" class="rounded-full bg-[#36474F] px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-[#D3A373]">
          Zapytaj o termin
        </a>
      </div>
    </header>

    <!-- HERO -->
    <section id="start" class="soft-grid relative min-h-screen overflow-hidden pt-24">
      <div class="absolute -right-40 top-20 h-[34rem] w-[34rem] rounded-full bg-[#F6CED7]/70 blur-3xl"></div>
      <div class="absolute -bottom-40 -left-40 h-[34rem] w-[34rem] rounded-full bg-[#D3A373]/35 blur-3xl"></div>

      <div class="relative mx-auto grid min-h-[calc(100vh-6rem)] max-w-7xl items-center gap-12 px-5 py-14 lg:grid-cols-[0.9fr_1.1fr] lg:px-8">
        <div>
          <p class="mb-5 text-xs font-bold uppercase tracking-[0.42em] text-[#D3A373]">
            Pracownia cukiernicza · okolice Chełma
          </p>

          <h1 class="display-font max-w-3xl text-6xl font-semibold leading-[0.9] tracking-[-0.055em] text-[#36474F] md:text-8xl lg:text-9xl">
            The Cake
          </h1>

          <p class="display-font mt-5 max-w-2xl text-4xl leading-[1.05] tracking-[-0.045em] text-[#36474F] md:text-6xl">
            torty, które wyglądają jak część wspomnienia.
          </p>

          <p class="mt-8 max-w-xl text-lg leading-8 text-[#36474F]/72">
            Artystyczne torty, słodkie stoły i desery tworzone indywidualnie na wesela,
            przyjęcia, rodzinne uroczystości oraz realizacje firmowe.
          </p>

          <div class="mt-10 flex flex-col gap-4 sm:flex-row">
            <a href="#kontakt" class="rounded-full bg-[#36474F] px-8 py-4 text-center text-sm font-bold text-white transition hover:-translate-y-0.5 hover:bg-[#D3A373]">
              Wyślij zapytanie
            </a>
            <a href="#galeria" class="rounded-full border border-[#36474F]/20 bg-white/50 px-8 py-4 text-center text-sm font-bold text-[#36474F] transition hover:-translate-y-0.5 hover:bg-white">
              Zobacz realizacje
            </a>
          </div>

          <div class="mt-12 grid max-w-xl grid-cols-3 gap-4">
            <div class="rounded-3xl bg-white/65 p-5 ring-1 ring-[#36474F]/10">
              <p class="display-font text-3xl font-semibold">01</p>
              <p class="mt-1 text-xs uppercase tracking-[0.22em] text-[#36474F]/60">projekty indywidualne</p>
            </div>
            <div class="rounded-3xl bg-white/65 p-5 ring-1 ring-[#36474F]/10">
              <p class="display-font text-3xl font-semibold">30 km</p>
              <p class="mt-1 text-xs uppercase tracking-[0.22em] text-[#36474F]/60">okolice Chełma</p>
            </div>
            <div class="rounded-3xl bg-white/65 p-5 ring-1 ring-[#36474F]/10">
              <p class="display-font text-3xl font-semibold">B2B</p>
              <p class="mt-1 text-xs uppercase tracking-[0.22em] text-[#36474F]/60">firmy i eventy</p>
            </div>
          </div>
        </div>

        <div class="relative">
          <div class="absolute -left-8 top-10 z-10 hidden rounded-full bg-[#D3A373] px-7 py-4 text-sm font-bold uppercase tracking-[0.22em] text-white shadow-xl md:block">
            handmade
          </div>

          <div class="image-frame relative overflow-hidden rounded-[3rem] bg-white p-3">
            <div class="relative aspect-[4/5] overflow-hidden rounded-[2.4rem]">
              <img src="/images/hero.jpeg" alt="Tort artystyczny The Cake" class="h-full w-full object-cover" />
              <div class="absolute inset-0 bg-gradient-to-t from-[#36474F]/65 via-[#36474F]/5 to-transparent"></div>

              <div class="absolute bottom-0 left-0 right-0 p-8 text-white md:p-10">
                <p class="text-xs font-bold uppercase tracking-[0.36em] text-white/75">
                  torty · słodkie stoły · desery
                </p>
                <p class="display-font mt-3 max-w-md text-4xl font-semibold leading-none tracking-[-0.035em] md:text-5xl">
                  Każda realizacja tworzona jest na zamówienie.
                </p>
              </div>
            </div>
          </div>

          <div class="absolute -bottom-8 right-4 hidden w-72 rounded-[2rem] bg-white p-6 shadow-2xl shadow-[#36474F]/15 ring-1 ring-[#36474F]/10 lg:block">
            <p class="text-xs font-bold uppercase tracking-[0.32em] text-[#D3A373]">signature</p>
            <p class="display-font mt-3 text-3xl leading-none">Piękno, smak i detal.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- STATEMENT -->
    <section class="bg-[#36474F] px-5 py-20 text-white lg:px-8">
      <div class="mx-auto grid max-w-7xl gap-10 lg:grid-cols-[0.8fr_1.2fr]">
        <p class="text-xs font-bold uppercase tracking-[0.42em] text-[#D3A373]">
          Charakter marki
        </p>

        <div>
          <h2 class="display-font max-w-5xl text-4xl font-semibold leading-[1.05] tracking-[-0.045em] md:text-6xl">
            To nie jest masowa cukiernia. To lokalna pracownia, w której tort ma być
            równie piękny, jak smaczny.
          </h2>

          <div class="mt-12 grid gap-5 md:grid-cols-3">
            <div class="rounded-[2rem] bg-white/[0.06] p-7 ring-1 ring-white/10">
              <p class="display-font text-4xl text-[#D3A373]">01</p>
              <h3 class="mt-6 text-xl font-semibold">Indywidualnie</h3>
              <p class="mt-3 leading-7 text-white/65">Projekt dopasowany do okazji, stylu wydarzenia i inspiracji klienta.</p>
            </div>

            <div class="rounded-[2rem] bg-white/[0.06] p-7 ring-1 ring-white/10">
              <p class="display-font text-4xl text-[#D3A373]">02</p>
              <h3 class="mt-6 text-xl font-semibold">Estetycznie</h3>
              <p class="mt-3 leading-7 text-white/65">Kolor, forma, dekoracje i detale mają tworzyć spójną całość.</p>
            </div>

            <div class="rounded-[2rem] bg-white/[0.06] p-7 ring-1 ring-white/10">
              <p class="display-font text-4xl text-[#D3A373]">03</p>
              <h3 class="mt-6 text-xl font-semibold">Profesjonalnie</h3>
              <p class="mt-3 leading-7 text-white/65">Od zapytania i wyceny po odbiór, dowóz lub montaż słodkiego stołu.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- OFFER -->
    <section id="oferta" class="relative overflow-hidden bg-[#FFF5E1] px-5 py-24 lg:px-8">
      <div class="absolute right-0 top-0 h-96 w-96 rounded-full bg-[#F6CED7]/45 blur-3xl"></div>

      <div class="relative mx-auto max-w-7xl">
        <div class="mb-14 flex flex-col justify-between gap-8 md:flex-row md:items-end">
          <div>
            <p class="text-xs font-bold uppercase tracking-[0.42em] text-[#D3A373]">
              Oferta
            </p>
            <h2 class="display-font mt-4 max-w-3xl text-5xl font-semibold leading-none tracking-[-0.055em] md:text-7xl">
              Słodka oprawa ważnych okazji.
            </h2>
          </div>

          <p class="max-w-md leading-8 text-[#36474F]/70">
            Oferta została ułożona tak, żeby użytkownik od razu widział, czym zajmuje się The Cake:
            torty, wesela, słodkie stoły i realizacje firmowe.
          </p>
        </div>

        <div class="grid gap-6">
          {offers.map((offer, index) => (
            <article class={`group grid overflow-hidden rounded-[3rem] bg-white p-3 ring-1 ring-[#36474F]/10 transition hover:-translate-y-1 hover:shadow-2xl hover:shadow-[#36474F]/12 lg:grid-cols-2 ${index % 2 === 1 ? 'lg:[&>*:first-child]:order-2' : ''}`}>
              <div class="relative min-h-[360px] overflow-hidden rounded-[2.4rem] md:min-h-[480px]">
                <img src={offer.image} alt={offer.title} class="h-full w-full object-cover transition duration-700 group-hover:scale-105" />
                <div class="absolute inset-0 bg-gradient-to-t from-[#36474F]/72 via-[#36474F]/10 to-transparent"></div>

                <div class="absolute left-7 top-7 rounded-full bg-[#FFF5E1]/90 px-5 py-2 text-xs font-bold uppercase tracking-[0.25em] text-[#36474F]">
                  {offer.tag}
                </div>

                <div class="absolute bottom-7 left-7 right-7 text-white">
                  <p class="display-font text-6xl leading-none text-[#D3A373]">{offer.number}</p>
                  <h3 class="display-font mt-3 text-5xl font-semibold leading-none tracking-[-0.04em]">
                    {offer.title}
                  </h3>
                </div>
              </div>

              <div class="flex min-h-[360px] flex-col justify-between p-7 md:p-12">
                <div>
                  <p class="text-xs font-bold uppercase tracking-[0.36em] text-[#D3A373]">The Cake offer</p>
                  <p class="display-font mt-8 max-w-xl text-4xl font-semibold leading-tight tracking-[-0.04em] md:text-5xl">
                    Projekt dopasowany do okazji, nie gotowy produkt z katalogu.
                  </p>
                </div>

                <div>
                  <p class="max-w-xl text-lg leading-8 text-[#36474F]/70">{offer.text}</p>
                  <a href="#kontakt" class="mt-8 inline-flex rounded-full bg-[#36474F] px-7 py-3 text-sm font-bold text-white transition hover:bg-[#D3A373]">
                    Zapytaj o realizację
                  </a>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- GALLERY -->
    <section id="galeria" class="bg-white px-5 py-24 lg:px-8">
      <div class="mx-auto max-w-7xl">
        <div class="mb-14 grid gap-8 lg:grid-cols-[0.8fr_1.2fr]">
          <p class="text-xs font-bold uppercase tracking-[0.42em] text-[#D3A373]">
            Galeria
          </p>
          <h2 class="display-font max-w-5xl text-5xl font-semibold leading-none tracking-[-0.055em] md:text-7xl">
            Zdjęcia mają sprzedawać jakość szybciej niż tekst.
          </h2>
        </div>

        <div class="grid auto-rows-[260px] gap-5 md:grid-cols-4 md:auto-rows-[280px]">
          {gallery.map((item) => (
            <figure
              class={`group relative overflow-hidden rounded-[2.4rem] bg-[#FFF5E1] p-2 ring-1 ring-[#36474F]/10
                ${item.size === 'large' ? 'md:col-span-2 md:row-span-2' : ''}
                ${item.size === 'wide' ? 'md:col-span-2' : ''}
              `}
            >
              <div class="relative h-full overflow-hidden rounded-[1.9rem]">
                <img src={item.image} alt={item.title} class="h-full w-full object-cover transition duration-700 group-hover:scale-105" />
                <div class="absolute inset-0 bg-gradient-to-t from-[#36474F]/65 via-transparent to-transparent"></div>
                <figcaption class="absolute bottom-6 left-6 rounded-full bg-[#FFF5E1]/90 px-5 py-2 text-xs font-bold uppercase tracking-[0.25em] text-[#36474F]">
                  {item.title}
                </figcaption>
              </div>
            </figure>
          ))}
        </div>
      </div>
    </section>

    <!-- PROCESS -->
    <section id="proces" class="soft-grid bg-[#F6CED7]/45 px-5 py-24 lg:px-8">
      <div class="mx-auto max-w-7xl">
        <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr]">
          <div>
            <p class="text-xs font-bold uppercase tracking-[0.42em] text-[#D3A373]">
              Proces
            </p>
            <h2 class="display-font mt-4 text-5xl font-semibold leading-none tracking-[-0.055em] md:text-7xl">
              Jak wygląda zamówienie?
            </h2>
          </div>

          <div class="grid gap-5 md:grid-cols-2">
            {steps.map(([number, title, text]) => (
              <div class="rounded-[2.2rem] bg-white/75 p-8 ring-1 ring-[#36474F]/10 backdrop-blur">
                <p class="display-font text-5xl text-[#D3A373]">{number}</p>
                <h3 class="mt-8 text-2xl font-bold">{title}</h3>
                <p class="mt-4 leading-7 text-[#36474F]/68">{text}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- LOCAL / B2B -->
    <section class="bg-[#FFF5E1] px-5 py-24 lg:px-8">
      <div class="mx-auto grid max-w-7xl gap-6 lg:grid-cols-2">
        <div class="relative overflow-hidden rounded-[3rem] bg-[#36474F] p-10 text-white md:p-12">
          <div class="absolute -right-24 -top-24 h-72 w-72 rounded-full bg-[#D3A373]/25 blur-3xl"></div>
          <p class="text-xs font-bold uppercase tracking-[0.42em] text-[#D3A373]">Obszar działania</p>
          <h2 class="display-font mt-5 text-5xl font-semibold leading-none tracking-[-0.05em]">
            Chełm i okolice do około 30 km.
          </h2>
          <p class="mt-7 max-w-xl leading-8 text-white/68">
            Przy większych realizacjach, takich jak wesela i słodkie stoły, możliwy jest dowóz,
            montaż oraz kompleksowa obsługa na miejscu wydarzenia.
          </p>

          <div class="mt-8 flex flex-wrap gap-3">
            {['Chełm', 'Siedliszcze', 'Rejowiec', 'Krasnystaw', 'Łęczna', 'okolice'].map((city) => (
              <span class="rounded-full bg-white/10 px-5 py-2 text-sm text-white/80 ring-1 ring-white/10">
                {city}
              </span>
            ))}
          </div>
        </div>

        <div class="relative overflow-hidden rounded-[3rem] bg-white p-10 ring-1 ring-[#36474F]/10 md:p-12">
          <div class="absolute -right-24 -bottom-24 h-72 w-72 rounded-full bg-[#F6CED7]/70 blur-3xl"></div>
          <p class="text-xs font-bold uppercase tracking-[0.42em] text-[#D3A373]">Dla firm</p>
          <h2 class="display-font mt-5 text-5xl font-semibold leading-none tracking-[-0.05em]">
            Boxy, eventy i słodkie realizacje B2B.
          </h2>
          <p class="mt-7 max-w-xl leading-8 text-[#36474F]/70">
            Oferta dla firm może obejmować boxy prezentowe, słodkie stoły na eventy, zamówienia sezonowe
            i indywidualne realizacje dla lokalnych partnerów.
          </p>

          <a href="#kontakt" class="mt-9 inline-flex rounded-full bg-[#36474F] px-7 py-3 text-sm font-bold text-white transition hover:bg-[#D3A373]">
            Zapytaj o ofertę firmową
          </a>
        </div>
      </div>
    </section>

    <!-- FAQ + CONTACT -->
    <section id="faq" class="bg-white px-5 py-24 lg:px-8">
      <div class="mx-auto grid max-w-7xl gap-12 lg:grid-cols-[0.85fr_1.15fr]">
        <div id="kontakt">
          <p class="text-xs font-bold uppercase tracking-[0.42em] text-[#D3A373]">
            Kontakt
          </p>
          <h2 class="display-font mt-4 text-5xl font-semibold leading-none tracking-[-0.055em] md:text-7xl">
            Zapytaj o termin i wycenę.
          </h2>

          <p class="mt-7 max-w-xl leading-8 text-[#36474F]/70">
            Podaj datę wydarzenia, liczbę osób, miejscowość, rodzaj realizacji i inspiracje.
            To pozwoli szybciej przygotować konkretną odpowiedź.
          </p>

          <div class="mt-10 rounded-[2.5rem] bg-[#FFF5E1] p-8 ring-1 ring-[#36474F]/10">
            <p class="text-sm"><span class="font-bold">Instagram:</span> @thecake</p>
            <p class="mt-3 text-sm"><span class="font-bold">Facebook:</span> The Cake</p>
            <p class="mt-3 text-sm"><span class="font-bold">Telefon:</span> +48 000 000 000</p>
            <p class="mt-3 text-sm"><span class="font-bold">E-mail:</span> kontakt@thecake.pl</p>

            <a href="mailto:kontakt@thecake.pl?subject=Zapytanie%20o%20realizację%20The%20Cake" class="mt-7 inline-flex w-full justify-center rounded-full bg-[#36474F] px-7 py-4 text-sm font-bold text-white transition hover:bg-[#D3A373]">
              Wyślij zapytanie mailowe
            </a>
          </div>
        </div>

        <div class="space-y-4">
          {faqs.map(([question, answer]) => (
            <details class="group rounded-[2rem] bg-[#FFF5E1] p-7 ring-1 ring-[#36474F]/10">
              <summary class="flex cursor-pointer list-none items-center justify-between gap-5 text-lg font-bold">
                {question}
                <span class="text-3xl text-[#D3A373] transition group-open:rotate-45">+</span>
              </summary>
              <p class="mt-5 leading-8 text-[#36474F]/70">{answer}</p>
            </details>
          ))}

          <div class="overflow-hidden rounded-[2rem] bg-[#36474F] p-2">
            <div class="relative min-h-[340px] overflow-hidden rounded-[1.6rem]">
              <img src="/images/about.jpeg" alt="The Cake realizacja" class="h-full w-full object-cover" />
              <div class="absolute inset-0 bg-gradient-to-t from-[#36474F]/80 via-[#36474F]/20 to-transparent"></div>
              <div class="absolute bottom-7 left-7 right-7 text-white">
                <p class="text-xs font-bold uppercase tracking-[0.35em] text-[#D3A373]">The Cake</p>
                <p class="display-font mt-3 text-4xl leading-none">Tworzymy słodkie wspomnienia.</p>
              </div>
            </div>
          </div>
