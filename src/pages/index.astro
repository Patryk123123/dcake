---
import Layout from '../layouts/Layout.astro';

const offers = [
  {
    label: '01',
    title: 'Torty okolicznościowe',
    text: 'Indywidualne torty na urodziny, chrzciny, komunie, baby shower, jubileusze i rodzinne uroczystości.',
    image: '/images/offer-occasion.jpeg',
    alt: 'Tort okolicznościowy The Cake',
  },
  {
    label: '02',
    title: 'Torty weselne',
    text: 'Eleganckie torty jedno- i wielopiętrowe, dopasowane do stylu przyjęcia, dekoracji i liczby gości.',
    image: '/images/offer-wedding.jpeg',
    alt: 'Tort weselny The Cake',
  },
  {
    label: '03',
    title: 'Słodkie stoły',
    text: 'Kompleksowa realizacja: desery, dekoracja stołu, transport, montaż i odbiór dekoracji po wydarzeniu.',
    image: '/images/offer-sweet-table.jpeg',
    alt: 'Słodki stół The Cake',
  },
  {
    label: '04',
    title: 'Boxy i realizacje firmowe',
    text: 'Słodkie upominki, boxy prezentowe oraz realizacje dla firm, eventów i lokalnych partnerów.',
    image: '/images/offer-business.jpeg',
    alt: 'Boxy prezentowe The Cake',
  },
];

const gallery = [
  { image: '/images/gallery-1.jpeg', alt: 'Tort artystyczny The Cake', title: 'Tort artystyczny' },
  { image: '/images/gallery-2.jpeg', alt: 'Tort weselny The Cake', title: 'Tort weselny' },
  { image: '/images/gallery-3.jpeg', alt: 'Słodki stół The Cake', title: 'Słodki stół' },
  { image: '/images/gallery-4.jpeg', alt: 'Desery The Cake', title: 'Desery' },
  { image: '/images/gallery-5.jpeg', alt: 'Tort personalizowany The Cake', title: 'Personalizacja' },
  { image: '/images/gallery-6.jpeg', alt: 'Słodka realizacja The Cake', title: 'Realizacja' },
];

const steps = [
  {
    number: '01',
    title: 'Zapytanie',
    text: 'Wysyłasz datę, liczbę osób, rodzaj realizacji i inspiracje.',
  },
  {
    number: '02',
    title: 'Ustalenia',
    text: 'Dobieramy styl, smak, dekoracje oraz formę odbioru lub dostawy.',
  },
  {
    number: '03',
    title: 'Wycena',
    text: 'Otrzymujesz propozycję przygotowaną pod konkretne wydarzenie.',
  },
  {
    number: '04',
    title: 'Realizacja',
    text: 'Tworzymy tort, desery lub słodki stół z dbałością o detale.',
  },
];

const faqs = [
  {
    question: 'Ile wcześniej złożyć zamówienie?',
    answer: 'Najlepiej minimum 2–3 tygodnie wcześniej. Przy weselach i słodkich stołach warto skontaktować się jeszcze wcześniej.',
  },
  {
    question: 'Czy mogę wysłać inspiracje?',
    answer: 'Tak. Możesz przesłać zdjęcia, kolorystykę wydarzenia, motyw przewodni lub opis stylu, który Ci się podoba.',
  },
  {
    question: 'Czy jest możliwa dostawa?',
    answer: 'Tak. Realizacje wykonujemy lokalnie w okolicach Chełma, a przy większych zamówieniach możliwy jest dowóz i montaż.',
  },
  {
    question: 'Czy robicie słodkie stoły?',
    answer: 'Tak. Słodki stół może obejmować desery, dekorację, transport, montaż oraz odbiór dekoracji po wydarzeniu.',
  },
];
---

<Layout>
  <main class="min-h-screen bg-[#FFF5E1] text-[#36474F] selection:bg-[#D3A373]/30">
    <!-- HEADER -->
    <header class="fixed left-0 top-0 z-50 w-full border-b border-[#36474F]/10 bg-[#FFF5E1]/85 backdrop-blur-xl">
      <div class="mx-auto flex max-w-7xl items-center justify-between px-5 py-4 lg:px-8">
        <a href="#start" class="text-base font-semibold uppercase tracking-[0.28em] text-[#36474F]">
          The Cake
        </a>

        <nav class="hidden items-center gap-8 text-sm text-[#36474F]/70 md:flex">
          <a href="#oferta" class="transition hover:text-[#D3A373]">Oferta</a>
          <a href="#galeria" class="transition hover:text-[#D3A373]">Galeria</a>
          <a href="#wspolpraca" class="transition hover:text-[#D3A373]">Współpraca</a>
          <a href="#obszar" class="transition hover:text-[#D3A373]">Obszar</a>
          <a href="#kontakt" class="transition hover:text-[#D3A373]">Kontakt</a>
        </nav>

        <a
          href="#kontakt"
          class="rounded-full bg-[#36474F] px-5 py-2.5 text-sm font-medium text-white transition hover:bg-[#D3A373]"
        >
          Zapytaj o termin
        </a>
      </div>
    </header>

    <!-- HERO -->
    <section id="start" class="relative overflow-hidden pt-24">
      <div class="absolute right-[-12rem] top-20 h-[34rem] w-[34rem] rounded-full bg-[#F6CED7]/45 blur-3xl"></div>
      <div class="absolute bottom-[-16rem] left-[-12rem] h-[34rem] w-[34rem] rounded-full bg-[#D3A373]/25 blur-3xl"></div>

      <div class="relative mx-auto grid min-h-[92vh] max-w-7xl items-center gap-12 px-5 py-16 lg:grid-cols-[0.92fr_1.08fr] lg:px-8">
        <div class="max-w-2xl">
          <p class="mb-6 text-xs font-semibold uppercase tracking-[0.42em] text-[#D3A373]">
            Pracownia cukiernicza
          </p>

          <h1 class="text-5xl font-semibold leading-[0.95] tracking-[-0.04em] text-[#36474F] md:text-7xl lg:text-8xl">
            Torty, które zostają w pamięci.
          </h1>

          <p class="mt-8 max-w-xl text-lg leading-8 text-[#36474F]/72">
            Artystyczne torty, słodkie stoły i desery na zamówienie.
            Tworzone indywidualnie na wesela, przyjęcia i wyjątkowe okazje
            w okolicach Chełma.
          </p>

          <div class="mt-10 flex flex-col gap-4 sm:flex-row">
            <a
              href="#kontakt"
              class="rounded-full bg-[#36474F] px-8 py-4 text-center text-sm font-medium text-white transition hover:-translate-y-0.5 hover:bg-[#D3A373]"
            >
              Wyślij zapytanie
            </a>

            <a
              href="#galeria"
              class="rounded-full border border-[#36474F]/18 bg-white/45 px-8 py-4 text-center text-sm font-medium text-[#36474F] transition hover:-translate-y-0.5 hover:bg-white"
            >
              Zobacz realizacje
            </a>
          </div>

          <div class="mt-12 grid max-w-lg grid-cols-3 gap-6 border-t border-[#36474F]/10 pt-8">
            <div>
              <p class="text-2xl font-semibold text-[#36474F]">100%</p>
              <p class="mt-1 text-xs uppercase tracking-[0.18em] text-[#36474F]/55">na zamówienie</p>
            </div>
            <div>
              <p class="text-2xl font-semibold text-[#36474F]">30 km</p>
              <p class="mt-1 text-xs uppercase tracking-[0.18em] text-[#36474F]/55">okolice Chełma</p>
            </div>
            <div>
              <p class="text-2xl font-semibold text-[#36474F]">B2B</p>
              <p class="mt-1 text-xs uppercase tracking-[0.18em] text-[#36474F]/55">firmy i eventy</p>
            </div>
          </div>
        </div>

        <div class="relative">
          <div class="grid gap-5 sm:grid-cols-[0.75fr_1fr]">
            <div class="hidden flex-col gap-5 pt-16 sm:flex">
              <div class="aspect-[4/5] overflow-hidden rounded-[2rem] bg-white shadow-xl shadow-[#36474F]/10">
                <img src="/images/gallery-2.jpeg" alt="Tort The Cake" class="h-full w-full object-cover" />
              </div>
              <div class="rounded-[2rem] bg-white/70 p-6 ring-1 ring-[#36474F]/10">
                <p class="text-xs uppercase tracking-[0.28em] text-[#D3A373]">The Cake</p>
                <p class="mt-3 text-xl font-semibold leading-tight">Piękno, smak i detal w jednej realizacji.</p>
              </div>
            </div>

            <div class="aspect-[4/5] overflow-hidden rounded-[2.4rem] bg-white shadow-2xl shadow-[#36474F]/15">
              <img src="/images/hero.jpeg" alt="Tort artystyczny The Cake" class="h-full w-full object-cover" />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- INTRO -->
    <section class="bg-white px-5 py-20 lg:px-8">
      <div class="mx-auto grid max-w-7xl gap-12 lg:grid-cols-[0.8fr_1.2fr]">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.38em] text-[#D3A373]">
            O marce
          </p>
        </div>

        <div>
          <h2 class="max-w-4xl text-3xl font-semibold leading-tight tracking-[-0.03em] text-[#36474F] md:text-5xl">
            The Cake to lokalna pracownia, która nie tworzy masowych wypieków.
            Każdy projekt powstaje indywidualnie — pod okazję, styl i emocje wydarzenia.
          </h2>

          <div class="mt-10 grid gap-6 md:grid-cols-3">
            <div class="border-t border-[#36474F]/12 pt-5">
              <h3 class="font-semibold">Estetyka</h3>
              <p class="mt-3 text-sm leading-6 text-[#36474F]/68">
                Minimalistyczne, eleganckie realizacje z dbałością o kolor, proporcje i detale.
              </p>
            </div>
            <div class="border-t border-[#36474F]/12 pt-5">
              <h3 class="font-semibold">Smak</h3>
              <p class="mt-3 text-sm leading-6 text-[#36474F]/68">
                Desery mają nie tylko wyglądać dobrze, ale też zachwycać od pierwszego kęsa.
              </p>
            </div>
            <div class="border-t border-[#36474F]/12 pt-5">
              <h3 class="font-semibold">Obsługa</h3>
              <p class="mt-3 text-sm leading-6 text-[#36474F]/68">
                Od koncepcji po dowóz i montaż — szczególnie przy weselach i słodkich stołach.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- OFFER -->
    <section id="oferta" class="bg-[#FFF5E1] px-5 py-24 lg:px-8">
      <div class="mx-auto max-w-7xl">
        <div class="mb-14 flex flex-col justify-between gap-8 md:flex-row md:items-end">
          <div class="max-w-2xl">
            <p class="text-xs font-semibold uppercase tracking-[0.38em] text-[#D3A373]">
              Oferta
            </p>
            <h2 class="mt-4 text-4xl font-semibold tracking-[-0.04em] md:text-6xl">
              Na wyjątkowe okazje.
            </h2>
          </div>

          <p class="max-w-md text-base leading-7 text-[#36474F]/70">
            Oferta obejmuje torty, słodkie stoły, desery i realizacje dla firm.
            Każda wycena przygotowywana jest indywidualnie.
          </p>
        </div>

        <div class="space-y-6">
          {offers.map((offer) => (
            <article class="group grid overflow-hidden rounded-[2rem] bg-white ring-1 ring-[#36474F]/10 transition hover:shadow-2xl hover:shadow-[#36474F]/10 lg:grid-cols-[0.9fr_1.1fr]">
              <div class="aspect-[16/10] overflow-hidden lg:aspect-auto">
                <img
                  src={offer.image}
                  alt={offer.alt}
                  class="h-full w-full object-cover transition duration-700 group-hover:scale-105"
                />
              </div>

              <div class="flex min-h-[320px] flex-col justify-between p-8 md:p-12">
                <div class="flex items-start justify-between gap-6">
                  <p class="text-sm font-semibold tracking-[0.28em] text-[#D3A373]">{offer.label}</p>
                  <div class="h-px flex-1 bg-[#36474F]/10"></div>
                </div>

                <div>
                  <h3 class="text-3xl font-semibold tracking-[-0.03em] md:text-5xl">
                    {offer.title}
                  </h3>
                  <p class="mt-6 max-w-xl text-base leading-8 text-[#36474F]/70">
                    {offer.text}
                  </p>
                </div>

                <a href="#kontakt" class="mt-8 inline-flex w-fit items-center text-sm font-semibold text-[#36474F] transition hover:text-[#D3A373]">
                  Zapytaj o realizację →
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- GALLERY -->
    <section id="galeria" class="bg-white px-5 py-24 lg:px-8">
      <div class="mx-auto max-w-7xl">
        <div class="mb-14 max-w-3xl">
          <p class="text-xs font-semibold uppercase tracking-[0.38em] text-[#D3A373]">
            Galeria
          </p>
          <h2 class="mt-4 text-4xl font-semibold tracking-[-0.04em] md:text-6xl">
            Realizacje, które budują pierwsze wrażenie.
          </h2>
        </div>

        <div class="grid gap-5 md:grid-cols-4">
          <div class="group relative overflow-hidden rounded-[2rem] md:col-span-2 md:row-span-2">
            <img src={gallery[0].image} alt={gallery[0].alt} class="aspect-square h-full w-full object-cover transition duration-700 group-hover:scale-105" />
            <div class="absolute inset-0 bg-gradient-to-t from-[#36474F]/45 to-transparent"></div>
            <p class="absolute bottom-6 left-6 text-sm font-medium text-white">{gallery[0].title}</p>
          </div>

          {gallery.slice(1).map((item) => (
            <div class="group relative overflow-hidden rounded-[2rem]">
              <img src={item.image} alt={item.alt} class="aspect-square h-full w-full object-cover transition duration-700 group-hover:scale-105" />
              <div class="absolute inset-0 bg-gradient-to-t from-[#36474F]/40 to-transparent opacity-80"></div>
              <p class="absolute bottom-5 left-5 text-sm font-medium text-white">{item.title}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- PROCESS -->
    <section id="wspolpraca" class="bg-[#36474F] px-5 py-24 text-white lg:px-8">
      <div class="mx-auto max-w-7xl">
        <div class="grid gap-12 lg:grid-cols-[0.85fr_1.15fr]">
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.38em] text-[#D3A373]">
              Współpraca
            </p>
            <h2 class="mt-4 text-4xl font-semibold tracking-[-0.04em] md:text-6xl">
              Jak wygląda zamówienie?
            </h2>
            <p class="mt-6 max-w-md leading-8 text-white/68">
              Prosty proces pomaga szybko ustalić termin, zakres i wycenę realizacji.
            </p>
          </div>

          <div class="grid gap-4 md:grid-cols-2">
            {steps.map((step) => (
              <div class="rounded-[1.8rem] bg-white/[0.06] p-7 ring-1 ring-white/10">
                <p class="text-sm font-semibold tracking-[0.28em] text-[#D3A373]">{step.number}</p>
                <h3 class="mt-8 text-2xl font-semibold">{step.title}</h3>
                <p class="mt-4 leading-7 text-white/65">{step.text}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- AREA + B2B -->
    <section id="obszar" class="bg-[#FFF5E1] px-5 py-24 lg:px-8">
      <div class="mx-auto grid max-w-7xl gap-10 lg:grid-cols-2">
        <div class="rounded-[2.2rem] bg-white p-8 ring-1 ring-[#36474F]/10 md:p-12">
          <p class="text-xs font-semibold uppercase tracking-[0.38em] text-[#D3A373]">
            Lokalnie
          </p>
          <h2 class="mt-4 text-4xl font-semibold tracking-[-0.04em] md:text-5xl">
            Okolice Chełma i realizacje z dowozem.
          </h2>
          <p class="mt-6 leading-8 text-[#36474F]/70">
            Pracownia obsługuje klientów lokalnie — w promieniu około 30 km od Chełma.
            Przy większych realizacjach możliwy jest transport i montaż na miejscu.
          </p>

          <div class="mt-8 flex flex-wrap gap-3">
            {['Chełm', 'Siedliszcze', 'Rejowiec', 'Krasnystaw', 'Łęczna', 'okolice'].map((city) => (
              <span class="rounded-full bg-[#FFF5E1] px-5 py-2 text-sm text-[#36474F]/75 ring-1 ring-[#36474F]/10">
                {city}
              </span>
            ))}
          </div>
        </div>

        <div class="rounded-[2.2rem] bg-[#F6CED7]/35 p-8 ring-1 ring-[#36474F]/10 md:p-12">
          <p class="text-xs font-semibold uppercase tracking-[0.38em] text-[#D3A373]">
            Dla firm
          </p>
          <h2 class="mt-4 text-4xl font-semibold tracking-[-0.04em] md:text-5xl">
            Słodkie realizacje dla marek, eventów i partnerów.
          </h2>
          <p class="mt-6 leading-8 text-[#36474F]/70">
            Boxy prezentowe, słodkie stoły na eventy, realizacje sezonowe oraz zamówienia
            dla lokalnych firm. To dobry kierunek dla klientów B2B bez robienia osobnej strony.
          </p>

          <a
            href="#kontakt"
            class="mt-8 inline-flex rounded-full bg-[#36474F] px-7 py-3 text-sm font-medium text-white transition hover:bg-[#D3A373]"
          >
            Zapytaj o ofertę firmową
          </a>
        </div>
      </div>
    </section>

    <!-- ABOUT -->
    <section class="bg-white px-5 py-24 lg:px-8">
      <div class="mx-auto grid max-w-7xl items-center gap-12 lg:grid-cols-[0.9fr_1.1fr]">
        <div class="overflow-hidden rounded-[2.2rem] bg-[#FFF5E1]">
          <img src="/images/about.jpeg" alt="Realizacja The Cake" class="aspect-[4/5] h-full w-full object-cover" />
        </div>

        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.38em] text-[#D3A373]">
            Filozofia
          </p>
          <h2 class="mt-4 text-4xl font-semibold tracking-[-0.04em] md:text-6xl">
            Piękno, smak i jakość w jednym.
          </h2>
          <p class="mt-7 text-lg leading-8 text-[#36474F]/72">
            The Cake tworzy desery, które są częścią ważnych momentów — od rodzinnych
            uroczystości po wesela i wydarzenia firmowe. Każda realizacja ma być spójna,
            estetyczna i dopasowana do konkretnej okazji.
          </p>
        </div>
      </div>
    </section>

    <!-- FAQ + CONTACT -->
    <section id="kontakt" class="bg-[#FFF5E1] px-5 py-24 lg:px-8">
      <div class="mx-auto grid max-w-7xl gap-12 lg:grid-cols-[0.85fr_1.15fr]">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.38em] text-[#D3A373]">
            Kontakt
          </p>
          <h2 class="mt-4 text-4xl font-semibold tracking-[-0.04em] md:text-6xl">
            Zapytaj o termin i wycenę.
          </h2>
          <p class="mt-6 leading-8 text-[#36474F]/70">
            Najszybciej przygotujemy wycenę, jeśli podasz datę wydarzenia, liczbę osób,
            rodzaj realizacji, miejscowość oraz inspiracje.
          </p>

          <div class="mt-10 space-y-4 rounded-[2rem] bg-white p-7 ring-1 ring-[#36474F]/10">
            <p><span class="font-semibold">Instagram:</span> @thecake</p>
            <p><span class="font-semibold">Facebook:</span> The Cake</p>
            <p><span class="font-semibold">Telefon:</span> +48 000 000 000</p>
            <p><span class="font-semibold">E-mail:</span> kontakt@thecake.pl</p>
          </div>
        </div>

        <div class="space-y-4">
          {faqs.map((faq) => (
            <details class="group rounded-[1.5rem] bg-white p-6 ring-1 ring-[#36474F]/10">
              <summary class="flex cursor-pointer list-none items-center justify-between gap-5 font-semibold">
                {faq.question}
                <span class="text-2xl text-[#D3A373] transition group-open:rotate-45">+</span>
              </summary>
              <p class="mt-4 leading-7 text-[#36474F]/70">{faq.answer}</p>
            </details>
          ))}

          <a
            href="mailto:kontakt@thecake.pl?subject=Zapytanie%20o%20realizację%20The%20Cake"
            class="block rounded-[1.5rem] bg-[#36474F] p-7 text-white transition hover:bg-[#D3A373]"
          >
            <p class="text-sm uppercase tracking-[0.28em] text-white/70">Napisz wiadomość</p>
            <p class="mt-3 text-2xl font-semibold">Wyślij zapytanie mailowe →</p>
          </a>
        </div>
      </div>
    </section>

    <!-- FOOTER -->
    <footer class="bg-[#2B3940] px-5 py-10 text-white/60 lg:px-8">
      <div class="mx-auto flex max-w-7xl flex-col justify-between gap-6 md:flex-row md:items-center">
        <div>
          <p class="text-lg font-semibold uppercase tracking-[0.28em] text-white">The Cake</p>
          <p class="mt-2 text-sm">Torty artystyczne, słodkie stoły i desery na zamówienie.</p>
        </div>

        <div class="flex flex-wrap gap-5 text-sm">
          <a href="#oferta" class="hover:text-white">Oferta</a>
          <a href="#galeria" class="hover:text-white">Galeria</a>
          <a href="#wspolpraca" class="hover:text-white">Współpraca</a>
          <a href="#kontakt" class="hover:text-white">Kontakt</a>
        </div>
      </div>
    </footer>
  </main>
</Layout>